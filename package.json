{
  "name": "princess",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.10"
  },
  "bin": {
    "princess": "./src--cli-and-pipeline/cli.ts"
  },
  "scripts": {
    "start": "bun --conditions=browser run src--cli-and-pipeline/cli.ts",
    "dry-run:fixture": "bun run src--cli-and-pipeline/cli.ts optimize fixtures--sample-repos/sample-repo --dry-run",
    "dry-run:fixture:json": "bun run src--cli-and-pipeline/cli.ts optimize fixtures--sample-repos/sample-repo --dry-run --json",
    "apply:fixture": "bun run src--cli-and-pipeline/cli.ts optimize fixtures--sample-repos/sample-repo --force",
    "verify:fixture": "bun run src--cli-and-pipeline/cli.ts verify fixtures--sample-repos/sample-repo-princess",
    "dry-run:config-fixture": "bun run src--cli-and-pipeline/cli.ts optimize fixtures--sample-repos/config-rewrite-repo --dry-run",
    "apply:config-fixture": "bun run src--cli-and-pipeline/cli.ts optimize fixtures--sample-repos/config-rewrite-repo --force",
    "verify:config-fixture": "bun run src--cli-and-pipeline/cli.ts verify fixtures--sample-repos/config-rewrite-repo-princess",
    "tui:fixture": "bun --conditions=browser run src--cli-and-pipeline/cli.ts tui fixtures--sample-repos/sample-repo",
    "test:typeset": "bun run src--tui-and-renderer/typeset.test.ts",
    "test:motion": "bun --conditions=browser run src--tui-and-renderer/motion.test.ts",
    "test": "bun run test:typeset && bun run test:motion"
  },
  "dependencies": {
    "solid-js": "^1.9.12"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12"
  }
}
