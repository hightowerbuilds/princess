{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://princess.local/schemas/model-output.schema.json",
  "title": "Princess Model Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["repoSummary", "proposals"],
  "properties": {
    "repoSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rootName", "detectedStack"],
      "properties": {
        "rootName": {
          "type": "string",
          "minLength": 1
        },
        "detectedStack": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "relativePath",
          "currentName",
          "proposedName",
          "purpose",
          "directives",
          "confidence",
          "decision",
          "reasoning",
          "riskFlags"
        ],
        "properties": {
          "relativePath": {
            "type": "string",
            "minLength": 1
          },
          "currentName": {
            "type": "string",
            "minLength": 1
          },
          "proposedName": {
            "type": "string",
            "pattern": "^[a-z0-9-]+(?:--[a-z0-9-]+){0,3}$",
            "maxLength": 56
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "directives": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[a-z0-9-]+$"
            },
            "maxItems": 3
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "decision": {
            "type": "string",
            "enum": ["rename", "keep", "ignore"]
          },
          "reasoning": {
            "type": "string",
            "minLength": 1
          },
          "riskFlags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
