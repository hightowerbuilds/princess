{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@components/*": [
        "./src/components/*"
      ],
      "@lib/*": [
        "src/lib/*"
      ],
      "@types/*": [
        "./src/types/*"
      ],
      "@hooks/*": [
        "src/hooks/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "vite.config.ts"
  ]
}
